{
  "name": "sveltekit-openapi-docs",
  "version": "1.0.0",
  "description": "Auto-generate OpenAPI 3.0 specs from SvelteKit API routes with Zod schema support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "lint": "eslint src/"
  },
  "keywords": [
    "sveltekit",
    "openapi",
    "swagger",
    "zod",
    "api",
    "documentation",
    "generator",
    "vite-plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "comment-parser": "^1.4.0",
    "vite": ">=5.0.0",
    "zod": ">=3.19.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "comment-parser": "^1.4.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "zod": "^4.1.8"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "@types/node": "^25.3.5",
    "randexp": "^0.5.3",
    "tsx": "^4.20.4",
    "typescript": "^5.0.0",
    "zod-schema-faker": "^2.1.1"
  }
}
